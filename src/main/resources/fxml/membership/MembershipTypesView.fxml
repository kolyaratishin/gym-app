<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.Region?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gymapp.ui.membership.MembershipTypesController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <HBox spacing="10">
                <Button text="Додати тип абонемента" styleClass="button,primary-button" onAction="#onAddMembershipType"/>
                <Button text="Редагувати" onAction="#onEditMembershipType"/>
                <!-- РОЗПІРКА -->
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Деактивувати" styleClass="button,danger-button" onAction="#onDeactivateMembershipType"/>
                <Button text="Реактивувати" styleClass="button,success-button" onAction="#onReactivateMembershipType"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="membershipTypesTable">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="70"/>
                <TableColumn fx:id="nameColumn" text="Назва" prefWidth="220"/>
                <TableColumn fx:id="durationDaysColumn" text="Тривалість (дні)" prefWidth="130"/>
                <TableColumn fx:id="visitLimitColumn" text="Ліміт відвідувань" prefWidth="140"/>
                <TableColumn fx:id="priceColumn" text="Ціна" prefWidth="120"/>
                <TableColumn fx:id="activeColumn" text="Активний" prefWidth="100"/>
            </columns>
        </TableView>
    </center>

</BorderPane>