<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymapp.ui.client.EmptyClientFormController"
      styleClass="page-root">

    <padding>
        <Insets top="22" right="22" bottom="22" left="22"/>
    </padding>

    <VBox spacing="4">
        <Label text="Додати пустий номер" styleClass="page-title"/>
        <Label text="Створює пустий запис клієнта тільки з номером зошита" styleClass="muted-text"/>
    </VBox>

    <GridPane hgap="14" vgap="14" styleClass="section-card">
        <Label text="Номер клієнта" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="clientNumberField"
                   promptText="Наприклад: 15"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="errorLabel" text="" styleClass="error-label"/>

    <HBox spacing="12">
        <Button text="Зберегти"
                onAction="#onSave"
                styleClass="primary-button"/>

        <Button text="Скасувати"
                onAction="#onCancel"
                styleClass="button"/>
    </HBox>

</VBox>