<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.CheckBox?>
<VBox spacing="20"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymapp.ui.client.ClientMembershipFormController"
      styleClass="page-root">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="4">
        <Label text="Керування абонементом" styleClass="page-title"/>
        <Label fx:id="clientInfoLabel" text="" styleClass="muted-text"/>
    </VBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="16" styleClass="section-card" HBox.hgrow="ALWAYS">
            <Label text="Новий абонемент" styleClass="section-title"/>

            <GridPane hgap="18" vgap="16">
                <Label text="Тип абонемента" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="membershipTypeBox"
                          prefWidth="320"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="1"/>

                <Label text="Режим перенесення" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <CheckBox fx:id="manualModeCheckBox"
                          text="Внести існуючий абонемент"
                          GridPane.rowIndex="1"
                          GridPane.columnIndex="1"/>

                <Label text="Дата початку" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <DatePicker fx:id="startDatePicker"
                            prefWidth="220"
                            GridPane.rowIndex="2"
                            GridPane.columnIndex="1"/>

                <Label text="Дата завершення" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <DatePicker fx:id="endDatePicker"
                            prefWidth="220"
                            GridPane.rowIndex="3"
                            GridPane.columnIndex="1"/>

                <Label text="Залишок тренувань" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="remainingVisitsField"
                           promptText="Наприклад: 5"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="Поточний активний абонемент" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <Label fx:id="currentMembershipLabel"
                       wrapText="true"
                       maxWidth="420"
                       GridPane.rowIndex="5"
                       GridPane.columnIndex="1"/>

                <Label text="Дія при збереженні" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <Label fx:id="replacementInfoLabel"
                       wrapText="true"
                       maxWidth="420"
                       GridPane.rowIndex="6"
                       GridPane.columnIndex="1"/>
            </GridPane>
        </VBox>

        <VBox spacing="16" styleClass="section-card" HBox.hgrow="ALWAYS">
            <Label text="Прев’ю нового абонемента" styleClass="section-title"/>

            <GridPane hgap="18" vgap="16">
                <Label text="Політика" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="previewPolicyLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Дата завершення" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="previewEndDateLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Залишок відвідувань" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="previewRemainingVisitsLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Статус" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="previewStatusLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>

            <Separator/>

            <Label fx:id="errorLabel" text="" styleClass="error-label"/>
        </VBox>
    </HBox>

    <HBox spacing="12">
        <Button text="Зберегти"
                onAction="#onSave"
                styleClass="primary-button"/>

        <Button text="Закрити"
                onAction="#onClose"
                styleClass="button"/>
    </HBox>

</VBox>