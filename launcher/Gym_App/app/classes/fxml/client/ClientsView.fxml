<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gymapp.ui.client.main.ClientsController"
      spacing="18"
      styleClass="page-root">

    <Label text="Клієнти" styleClass="page-title"/>

    <VBox spacing="14" styleClass="section-card">
        <HBox spacing="12">
            <TextField fx:id="searchField"
                       promptText="Пошук клієнта..."
                       HBox.hgrow="ALWAYS"/>

            <Button text="Пошук"
                    onAction="#onSearch"
                    styleClass="button,primary-button"/>

            <Button text="Скинути"
                    onAction="#onReset"
                    styleClass="button"/>
        </HBox>

        <HBox spacing="12">
            <Button text="Додати клієнта"
                    onAction="#onAddClient"
                    styleClass="button,primary-button"/>

            <Button text="Редагувати"
                    onAction="#onEditClient"
                    styleClass="button"/>

            <Button text="Деталі"
                    onAction="#onViewDetails"
                    styleClass="button"/>
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="section-card">
        <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                <TableColumn fx:id="firstNameColumn" text="Ім'я" prefWidth="180"/>
                <TableColumn fx:id="lastNameColumn" text="Прізвище" prefWidth="200"/>
                <TableColumn fx:id="membershipNameColumn" text="Абонемент" prefWidth="220"/>
                <TableColumn fx:id="activeColumn" text="Статус" prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>

</VBox>